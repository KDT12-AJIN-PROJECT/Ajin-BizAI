# AJIN BizAI — Backend Environment Variables (Template)
#
# 이 파일은 템플릿. 실제 값은 backend/.env 파일에 입력 (.gitignore 됨).
# 출처: PRD v0.2 FINAL §17.1 + test_01_model_strategy.md §1.6
#
# 사용법:
#   cp backend/.env.example backend/.env
#   # 그 다음 backend/.env 파일을 편집해서 실제 API key / 모델 ID / 한도 입력
#
# 보안 주의:
#   - .env 파일은 절대 git commit / 채팅창 / 로그에 노출 금지
#   - API key 노출 시 즉시 console에서 revoke 후 재발급
#   - 콘솔에 spending limit + email alert 함께 설정 (test_03 §3.9)

# ─── 라우팅 정책 (PRD §14.2.1 / test_01 §1.1) ─────────
AI_PROVIDER=mock                       # hybrid | mock | openai | anthropic | local
AI_COST_MODE=balanced                  # balanced | cost_save | quality_first

# ─── Mock Policy (form_prd/2.md 후속 작업 — 현재는 문서화만, 코드 가드 미적용) ─────
# 차후 작업에서 코드에 가드 추가 예정. 지금은 .env.example에 변수만 노출.
MOCK_MODE=false                        # true일 때만 MockProvider 활성화 (현재: 미적용)
DISABLE_MOCK_FALLBACK=true             # AI 실패 시 Mock 자동 전환 금지 (현재: 미적용)

# ─── OpenAI (config — 실제 ID는 Phase 0 검증, PRD §14.2.2) ───
# console: https://platform.openai.com/api-keys
OPENAI_API_KEY=                        # sk-... (본인이 backend/.env에 직접 입력. .env.example에는 절대 입력 X)
OPENAI_MODEL_ANALYSIS=                 # Phase 0 검증 후 채움
OPENAI_MODEL_DRAFT=                    # Phase 0 검증 후 채움
# 2026-05-18: form_parser는 입력이 큼 (~37K tokens, 38페이지 form 기준) → 4o TPM(30K) 초과 시 mini로 분리
# 미설정 시 OPENAI_MODEL_ANALYSIS fallback. 권장: ANALYSIS=gpt-4o + FORM_PARSER=gpt-4o-mini
OPENAI_MODEL_FORM_PARSER=              #

# NOAPI-P3 (D4): 단가표 JSON 경로 (선택적). 미입력 시 services/ai_cost.py DEFAULT_PRICING_TABLE (모든 null) 사용.
#   schema: {<model>: {input_per_1m_tokens_usd, output_per_1m_tokens_usd, usd_to_krw_rate, verified_at, source}}
#   실 단가는 운영 적용 직전 별도 작업에서 입력. 미입력 시 cost_estimate_krw=None 허용 (main flow 무영향).
OPENAI_PRICING_PATH=                   #

# ─── Anthropic (config — 실제 ID는 Phase 0 검증) ─────────
# console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=                     # sk-ant-... (본인이 .env에 직접 입력)
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
ANTHROPIC_MODEL_OPUS=claude-opus-4-7   # premium_final_writer 전용 (PRD §14.2.4)

# ─── Local LLM (RTX 5060 / Mac Mini) ──────────────────
LOCAL_LLM_URL=http://localhost:1234/v1
LOCAL_LLM_MODEL=llama-3.1-8b-instruct

# ─── 임베딩 / Vector Store (PRD §15) ──────────────────
EMBEDDING_MODEL=bge-m3-ko              # bge-m3-ko | openai-large
EMBEDDING_URL=http://localhost:11434
VECTOR_STORE=sqlite                    # sqlite | pgvector (v0.3 검토)

# ─── 매칭 정책 (PRD §15 / §17.1) ──────────────────────
DEFAULT_MATCHING_THRESHOLD=0.70

# ─── 비용 한도 / 가격 설정 (test_03 §3.7 / §3.9) ──────
DAILY_COST_LIMIT_KRW=10000
MONTHLY_COST_LIMIT_KRW=300000
PRICING_CONFIG_PATH=../config/pricing.json   # 모델별 단가 외부 JSON

# ─── DB ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./ajin.db       # v0.2 = sqlite. v0.3 검토: postgresql://...

# ─── A-4-4 Table Normalizer + Promoter (b4-8.md §3.10) ─
# layout IR의 table block을 정규화 + LLM 누락 표 자동 승격
# false이면 해당 단계 건너뛰고 LLM 결과 그대로 사용
FORM_NORMALIZE_TABLE=true              # table_normalizer (header_path, title_candidate, is_fragment 계산)
FORM_AUTO_PROMOTE_TABLE=true           # table_promoter (FormQuestion table_input 자동 생성 + LLM table_schema 보정)

# ─── C-2 step2_confirmed gate precheck 예외 (b8.md §3) ─
# production은 false 고정. 개발/테스트 시 true로 precheck 모드 활성화.
# Request body에 allow_preconfirm=true 명시 + 이 env 변수도 true일 때만 gate 우회.
ALLOW_PRECONFIRM_PRECHECK=false

# ─── Deployment environment / CORS (main.py CORS 분기) ─
# development(default): localhost / 127.0.0.1 모든 dev 포트 허용 (Vite fallback 대응)
# production         : CORS_ALLOWED_ORIGINS의 origin만 허용 (비어 있으면 startup error)
APP_ENV=development
CORS_ALLOWED_ORIGINS=

# production 예시 (운영 URL 확정 후 backend/.env에서 사용):
# APP_ENV=production
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

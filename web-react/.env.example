# AJIN BizAI — Frontend Environment Variables (Vite, Template)
#
# 이 파일은 템플릿. 실제 값은 web-react/.env 파일에 입력 (.gitignore 됨).
# 출처: PRD v0.2 FINAL §17.1 / §17.2
#
# 사용법:
#   cp web-react/.env.example web-react/.env
#   # 그 다음 web-react/.env 파일을 편집
#
# NOTE: VITE_* 값은 브라우저 빌드에 포함되어 노출됨 (서버 secret 금지)

# ─── 백엔드 API (PRD §17.1) ─────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ─── 개발자 모드 토글 (PRD §17.2) ──────────────────
# 운영 환경에서는 반드시 false 로 설정 → Tab 7 토글 미노출
# 개발 환경 진입: ?dev=1 URL 파라미터 또는 토글
VITE_ENABLE_ANALYSIS_DEV_MODE=true

# ─── 검증 모드: mock fallback 차단 (Phase 4-G P0) ────
# true: API 실패 시 mock 데이터로 대체하지 않고 명확한 에러 노출 (브라우저 검증 세션 전용)
# false 또는 미설정: API 실패 시 NOTICE_MOCK/FORM_MOCK 등으로 대체 (오프라인 동작)
# 변경 후 dev server 재시작 필요
VITE_DISABLE_MOCK_FALLBACK=false

# ─── 외부 정부 데이터 API (v1 기반, 공개 키) ──────
VITE_API_KEY=YOUR_API_KEY
VITE_BIZ_KEY=YOUR_BIZ_KEY

VITE_BIZINFO_API_URL=https://www.bizinfo.go.kr/uss/rss/bizinfoApi.do
VITE_MSIT_API_URL=https://apis.data.go.kr/1721000/msitannouncementinfo/businessAnnouncMentList
VITE_MSS_API_URL=https://apis.data.go.kr/1421000/mssBizService_v2/getbizList_v2
VITE_KSTARTUP_API_URL=https://apis.data.go.kr/B552735/kisedKstartupService01/getBusinessInformation01
VITE_NOTICE_SEARCH_NM=자동차

# ─── DEMO 공고 표시 (기본 false) ────────────────────
# true 로 설정해야만 notices 없을 때 샘플카드 표시
VITE_ENABLE_DEMO_NOTICES=false
